// NyxCode StdLib: Choice Buttons
// Usage: use "stdlib/choice"
//        Choice options="Yes,No,Maybe"

component Choice(options: string) {
  data selected = ""

  div .nyx-choice {
    slot
  }

  style {
    .nyx-choice {
      display: flex
      flex-direction: column
      gap: 0.5rem
    }
  }
}
