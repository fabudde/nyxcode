# Fabian Budde — Personal Portfolio
# Built with NyxCode 🦞
# Dark/Light Mode with system detection + toggle

component ProjectCard {
  props icon title description url
  section {
    style {
      radius 16px
      padding 2rem
      transition all 0.3s ease
      position relative
      overflow hidden
      hover {
        transform translateY(-6px)
      }
      before {
        position absolute
        top 0
        left 0
        width 100%
        height 2px
        bg linear-gradient(90deg, #667eea, #f093fb)
      }
    }
    span .icon style="font-size: 2.5rem; display: block; margin-bottom: 1rem;"
    h3 .title style="font-size: 1.25rem; font-weight: 700; margin: 0 0 0.75rem 0;"
    p .description style="font-size: 0.9rem; line-height: 1.6; margin: 0 0 1.25rem 0; opacity: 0.7;"
    link "View Project →" href=.url style="color: #667eea; text-decoration: none; font-weight: 600; font-size: 0.85rem;"
  }
}

component SkillBadge {
  props label
  span .label {
    style {
      display inline-block
      padding 0.4rem 1rem
      radius 99px
      font-size 0.8rem
      font-weight 600
      transition all 0.2s ease
      hover {
        transform translateY(-2px)
      }
    }
  }
}

page / {
  head "<link href='https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap' rel='stylesheet'>"
  head "<meta name='viewport' content='width=device-width, initial-scale=1'>"
  head "<meta name='description' content='Fabian Budde — Software Developer & Entrepreneur. Building AI-native tools and e-commerce solutions.'>"
  head "<style>*,*::before,*::after{box-sizing:border-box}html{scroll-behavior:smooth}body{font-family:Inter,sans-serif;margin:0;padding:0;min-height:100vh;transition:background .3s,color .3s}::selection{background:#667eea;color:#fff}:root{--bg:#0a0a12;--text:#e0e0f0;--heading:#f0f0ff;--muted:#8888aa;--subtle:#666688;--card-bg:rgba(255,255,255,.03);--card-border:rgba(255,255,255,.08);--card-hover:rgba(255,255,255,.06);--badge-bg:rgba(102,126,234,.12);--badge-text:#99aaee;--badge-border:rgba(102,126,234,.2);--contact-border:rgba(102,126,234,.25);--footer-border:rgba(255,255,255,.05);--footer-text:#505070;--footer-sub:#404060;--btn-outline-border:rgba(102,126,234,.3);--btn-outline-text:#99aaee;--hero-fade:linear-gradient(180deg,transparent,#0a0a12);--toggle-bg:rgba(255,255,255,.1);--toggle-hover:rgba(255,255,255,.2);--accent-shadow:rgba(102,126,234,.15)}[data-theme=light]{--bg:#fff;--text:#1a1a2e;--heading:#0a0a12;--muted:#555566;--subtle:#777788;--card-bg:rgba(0,0,0,.02);--card-border:rgba(0,0,0,.08);--card-hover:rgba(0,0,0,.04);--badge-bg:rgba(102,126,234,.08);--badge-text:#4455aa;--badge-border:rgba(102,126,234,.15);--contact-border:rgba(102,126,234,.2);--footer-border:rgba(0,0,0,.06);--footer-text:#999;--footer-sub:#bbb;--btn-outline-border:rgba(102,126,234,.3);--btn-outline-text:#5566bb;--hero-fade:linear-gradient(180deg,transparent,#fff);--toggle-bg:rgba(0,0,0,.06);--toggle-hover:rgba(0,0,0,.12);--accent-shadow:rgba(102,126,234,.1)}@media(prefers-color-scheme:light){:root:not([data-theme=dark]){--bg:#fff;--text:#1a1a2e;--heading:#0a0a12;--muted:#555566;--subtle:#777788;--card-bg:rgba(0,0,0,.02);--card-border:rgba(0,0,0,.08);--card-hover:rgba(0,0,0,.04);--badge-bg:rgba(102,126,234,.08);--badge-text:#4455aa;--badge-border:rgba(102,126,234,.15);--contact-border:rgba(102,126,234,.2);--footer-border:rgba(0,0,0,.06);--footer-text:#999;--footer-sub:#bbb;--btn-outline-border:rgba(102,126,234,.3);--btn-outline-text:#5566bb;--hero-fade:linear-gradient(180deg,transparent,#fff);--toggle-bg:rgba(0,0,0,.06);--toggle-hover:rgba(0,0,0,.12);--accent-shadow:rgba(102,126,234,.1)}}body{background:var(--bg);color:var(--text)}.project-card{background:var(--card-bg);border:1px solid var(--card-border)}.project-card:hover{box-shadow:0 12px 32px var(--accent-shadow);border-color:rgba(102,126,234,.4);background:var(--card-hover)}.project-card h3{color:var(--heading)}.project-card p{color:var(--muted)}.skill-badge{background:var(--badge-bg);color:var(--badge-text);border:1px solid var(--badge-border)}.skill-badge:hover{background:rgba(102,126,234,.25);color:var(--heading)}.section-label{color:#667eea}.section-heading{color:var(--heading)}.muted-text{color:var(--muted)}.subtle-text{color:var(--subtle)}.hero-section{background:radial-gradient(ellipse at 20% 50%,rgba(102,126,234,.08) 0%,transparent 50%),radial-gradient(ellipse at 80% 20%,rgba(240,147,251,.06) 0%,transparent 50%),var(--bg)}.contact-link{color:var(--btn-outline-text);border:1px solid var(--contact-border)}.contact-link:hover{border-color:rgba(102,126,234,.5);background:rgba(102,126,234,.08)}.btn-outline{border:1px solid var(--btn-outline-border);color:var(--btn-outline-text)}.btn-outline:hover{border-color:rgba(102,126,234,.6);background:rgba(102,126,234,.1);transform:translateY(-2px)}.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(102,126,234,.3)}.theme-toggle{position:fixed;top:1.5rem;right:1.5rem;z-index:100;background:var(--toggle-bg);border:none;border-radius:50%;width:44px;height:44px;font-size:1.2rem;cursor:pointer;transition:all .3s;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(10px)}.theme-toggle:hover{background:var(--toggle-hover);transform:scale(1.1)}footer{border-top:1px solid var(--footer-border)}.footer-main{color:var(--footer-text)}.footer-sub{color:var(--footer-sub)}</style>"
  head "<script>(function(){var s=localStorage.getItem('theme');if(s)document.documentElement.setAttribute('data-theme',s)})()</script>"
  head "<button class='theme-toggle' onclick='toggleTheme()' aria-label='Toggle theme'><span id='theme-icon'>☀️</span></button>"
  head "<script>function toggleTheme(){var h=document.documentElement,c=h.getAttribute('data-theme'),d=!c?(window.matchMedia('(prefers-color-scheme:light)').matches?false:true):c==='dark',n=d?'light':'dark';h.setAttribute('data-theme',n);localStorage.setItem('theme',n);document.getElementById('theme-icon').textContent=n==='light'?'🌙':'☀️'}window.addEventListener('DOMContentLoaded',function(){var s=localStorage.getItem('theme'),l=s==='light'||(!s&&window.matchMedia('(prefers-color-scheme:light)').matches);document.getElementById('theme-icon').textContent=l?'🌙':'☀️'})</script>"

  animate fadeInUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  animate gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  animate float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  # ═══ HERO ═══
  section class="hero-section" {
    style {
      min-height 100vh
      display flex
      flex-direction column
      justify-content center
      align-items center
      text-align center
      padding 4rem 2rem
      position relative
      overflow hidden
      @mobile {
        min-height auto
        padding 6rem 1.5rem 4rem
      }
    }

    span "" style="position: absolute; bottom: 0; left: 0; width: 100%; height: 40%; background: var(--hero-fade); pointer-events: none; z-index: 0;"
    span "👋" style="font-size: 2rem; display: block; margin-bottom: 1rem; animation: float 3s ease-in-out infinite; position: relative; z-index: 1;"
    h1 "Fabian Budde" style="font-size: 4rem; font-weight: 900; margin: 0 0 1rem 0; background: linear-gradient(135deg, #667eea 0%, #9b6dff 50%, #f093fb 100%); background-size: 200% 200%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: gradientShift 4s ease infinite; position: relative; z-index: 1; letter-spacing: -0.02em; line-height: 1.1;"
    p "Software Developer & Entrepreneur" class="muted-text" style="font-size: 1.35rem; font-weight: 300; margin: 0 0 1.5rem 0; letter-spacing: 0.05em; position: relative; z-index: 1;"
    p "Self-taught since 2018. Building AI-native tools and the future of e-commerce." class="subtle-text" style="font-size: 1rem; max-width: 500px; line-height: 1.7; position: relative; z-index: 1; animation: fadeInUp 1s ease 0.3s both;"

    section {
      style {
        display flex
        gap 1rem
        margin-top 2.5rem
        position relative
        z-index 1
        @mobile { flex-direction column, align-items center }
      }
      link "View Projects ↓" href="#projects" class="btn-primary" style="display: inline-block; padding: 0.85rem 2rem; background: linear-gradient(135deg, #667eea, #764ba2); color: white; text-decoration: none; border-radius: 12px; font-weight: 600; font-size: 0.9rem; transition: all 0.3s ease;"
      link "GitHub →" href="https://github.com/fabudde" class="btn-outline" style="display: inline-block; padding: 0.85rem 2rem; text-decoration: none; border-radius: 12px; font-weight: 600; font-size: 0.9rem; transition: all 0.3s ease; background: transparent;"
    }
  }

  # ═══ ABOUT ═══
  section {
    style {
      padding 6rem 2rem
      max-width 800px
      margin 0 auto
      @mobile { padding 4rem 1.5rem }
    }
    span "About" class="section-label" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; display: block; margin-bottom: 1rem;"
    h2 "Building things that matter." class="section-heading" style="font-size: 2.25rem; font-weight: 800; margin: 0 0 1.5rem 0;"
    p "I started coding in 2018 — no degree, no bootcamp, just curiosity and stubbornness. Seven years later, I build AI-native programming languages, e-commerce platforms, and tools that help businesses scale." class="muted-text" style="font-size: 1.05rem; line-height: 1.8; margin: 0 0 1.25rem 0;"
    p "Based in the Sauerland, Germany. Co-Founder of Ayuni (Artificial Emotional Intelligence). Creator of NyxCode. Building the future with TypeScript, Rust, and a cosmic lobster by my side." class="muted-text" style="font-size: 1.05rem; line-height: 1.8; margin: 0;"
  }

  # ═══ PROJECTS ═══
  section id="projects" {
    style {
      padding 6rem 2rem
      max-width 1100px
      margin 0 auto
      @mobile { padding 4rem 1.5rem }
    }
    span "Projects" class="section-label" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; display: block; margin-bottom: 1rem; text-align: center;"
    h2 "What I've built." class="section-heading" style="font-size: 2.25rem; font-weight: 800; margin: 0 0 3rem 0; text-align: center;"

    section {
      style {
        display grid
        grid-template-columns repeat(3, 1fr)
        gap 1.5rem
        @mobile { grid-template-columns 1fr }
      }
      ProjectCard icon="🦞" title="NyxCode" description="AI-native programming language for the web. 68% fewer tokens than React. Zero config." url="https://github.com/fabudde/nyxcode"
      ProjectCard icon="🧠" title="Ayuni" description="Artificial Emotional Intelligence. Building AI that understands and responds to human emotions." url="https://ayuni.ai"
      ProjectCard icon="🎲" title="ShellGames.ai" description="AI-vs-AI gaming platform. Chess, Poker, Ludo — where artificial minds compete." url="https://shellgames.ai"
      ProjectCard icon="🔀" title="CrossCart" description="Cross-platform e-commerce migration. Seamlessly move shops between Shopware, WooCommerce, and more." url="https://github.com/fabudde"
      ProjectCard icon="🛒" title="ForkCart" description="Open source e-commerce framework. TypeScript, modular, extensible, developer-first." url="https://github.com/fabudde"
      ProjectCard icon="🏥" title="PraxisFix" description="Automated web agency for medical practices. AI-generated websites deployed in minutes." url="https://praxisfix.de"
    }
  }

  # ═══ SKILLS ═══
  section {
    style {
      padding 6rem 2rem
      max-width 800px
      margin 0 auto
      text-align center
      @mobile { padding 4rem 1.5rem }
    }
    span "Skills" class="section-label" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; display: block; margin-bottom: 1rem;"
    h2 "Technologies I work with." class="section-heading" style="font-size: 2.25rem; font-weight: 800; margin: 0 0 2.5rem 0;"
    section {
      style {
        display flex
        flex-wrap wrap
        justify-content center
        gap 0.75rem
      }
      SkillBadge label="TypeScript"
      SkillBadge label="PHP"
      SkillBadge label="Rust"
      SkillBadge label="Next.js"
      SkillBadge label="React"
      SkillBadge label="Node.js"
      SkillBadge label="Shopware 6"
      SkillBadge label="AI / LLM"
      SkillBadge label="PostgreSQL"
      SkillBadge label="Docker"
      SkillBadge label="Linux"
      SkillBadge label="Solana"
      SkillBadge label="MedusaJS"
      SkillBadge label="Caddy"
      SkillBadge label="WebSockets"
      SkillBadge label="Git"
    }
  }

  # ═══ CONTACT ═══
  section {
    style {
      padding 6rem 2rem
      text-align center
      max-width 600px
      margin 0 auto
      @mobile { padding 4rem 1.5rem }
    }
    span "Contact" class="section-label" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; display: block; margin-bottom: 1rem;"
    h2 "Let's build something." class="section-heading" style="font-size: 2.25rem; font-weight: 800; margin: 0 0 1.5rem 0;"
    p "Got an idea? Need a developer who speaks AI? Reach out." class="muted-text" style="font-size: 1.05rem; line-height: 1.7; margin: 0 0 2.5rem 0;"
    section {
      style {
        display flex
        justify-content center
        gap 1.5rem
        @mobile { flex-direction column, align-items center, gap 1rem }
      }
      link "fabian.budde@ff-web.de" href="mailto:fabian.budde@ff-web.de" class="contact-link" style="text-decoration: none; font-weight: 500; padding: 0.75rem 1.75rem; border-radius: 12px; transition: all 0.3s ease;"
      link "GitHub" href="https://github.com/fabudde" class="contact-link" style="text-decoration: none; font-weight: 500; padding: 0.75rem 1.75rem; border-radius: 12px; transition: all 0.3s ease;"
    }
  }

  # ═══ FOOTER ═══
  footer {
    style {
      padding 3rem 2rem
      text-align center
      margin-top 2rem
    }
    p "Built with NyxCode 🦞" class="footer-main" style="font-size: 0.85rem; margin: 0 0 0.5rem 0;"
    p "© 2026 Fabian Budde. All rights reserved." class="footer-sub" style="font-size: 0.75rem; margin: 0;"
  }
}
