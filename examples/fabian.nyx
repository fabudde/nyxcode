# Fabian Budde — Personal Portfolio
# Built with NyxCode 🦞
# Dark Mode Only — Green Accent — Unique Design

component ProjectCard {
  props icon title description url
  section {
    style {
      radius 16px
      padding 2rem
      transition all 0.4s cubic-bezier(0.4, 0, 0.2, 1)
      position relative
      overflow hidden
      hover {
        transform translateY(-8px)
      }
      before {
        position absolute
        top 0
        left 0
        width 100%
        height 2px
        bg linear-gradient(90deg, #00d26a, #00e676)
      }
    }
    span .icon style="font-size: 2.5rem; display: block; margin-bottom: 1rem;"
    h3 .title style="font-size: 1.25rem; font-weight: 700; margin: 0 0 0.75rem 0;"
    p .description style="font-size: 0.9rem; line-height: 1.6; margin: 0 0 1.25rem 0; opacity: 0.7;"
    link "View Project →" href=".url" style="color: #00d26a; text-decoration: none; font-weight: 600; font-size: 0.85rem; transition: color 0.3s;"
  }
}

component SkillBadge {
  props label
  span .label {
    style {
      display inline-block
      padding 0.4rem 1rem
      radius 99px
      font-size 0.8rem
      font-weight 600
      transition all 0.2s ease
      hover {
        transform translateY(-2px)
      }
    }
  }
}

page / {
  head "<link href='https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap' rel='stylesheet'>"
  head "<meta name='viewport' content='width=device-width, initial-scale=1'>"
  head "<meta name='description' content='Fabian Budde — Software Developer & Entrepreneur. Building AI-native tools and e-commerce solutions.'>"
  head "<style>*,*::before,*::after{box-sizing:border-box}html{scroll-behavior:smooth}body{font-family:Inter,sans-serif;margin:0;padding:0;min-height:100vh;background:#0a0a12;color:#e0e0f0;overflow-x:hidden}::selection{background:#00d26a;color:#0a0a12}.project-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08)}.project-card:hover{box-shadow:0 0 30px rgba(0,210,106,.12),0 12px 32px rgba(0,0,0,.4);border-color:rgba(0,210,106,.35);background:rgba(0,210,106,.04)}.project-card h3{color:#f0f0ff}.project-card p{color:#8888aa}.skill-badge{background:rgba(0,210,106,.08);color:#66ffb2;border:1px solid rgba(0,210,106,.18)}.skill-badge:hover{background:rgba(0,210,106,.2);color:#f0f0ff;border-color:rgba(0,210,106,.4);box-shadow:0 0 12px rgba(0,210,106,.15)}.section-label{color:#00d26a}.section-heading{color:#f0f0ff}.muted-text{color:#8888aa}.subtle-text{color:#666688}.hero-section{background:radial-gradient(ellipse at 20% 50%,rgba(0,210,106,.06) 0%,transparent 50%),radial-gradient(ellipse at 80% 20%,rgba(0,230,118,.04) 0%,transparent 50%),#0a0a12}.contact-link{color:#66ffb2;border:1px solid rgba(0,210,106,.25)}.contact-link:hover{border-color:rgba(0,210,106,.5);background:rgba(0,210,106,.08);box-shadow:0 0 20px rgba(0,210,106,.1)}.btn-outline{border:1px solid rgba(0,210,106,.3);color:#66ffb2}.btn-outline:hover{border-color:rgba(0,210,106,.6);background:rgba(0,210,106,.1);transform:translateY(-2px);box-shadow:0 0 20px rgba(0,210,106,.1)}.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,210,106,.3)}footer{border-top:1px solid rgba(255,255,255,.05)}.footer-main{color:#505070}.footer-sub{color:#404060}a{color:#00d26a!important}a:hover{color:#66ffb2!important;text-decoration:none!important}.bg-dots{position:fixed;top:0;left:0;width:100%;height:100%;background-image:radial-gradient(rgba(0,210,106,.07) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0}.orb{position:fixed;border-radius:50%;filter:blur(80px);opacity:.35;pointer-events:none;z-index:0}.orb-1{width:400px;height:400px;background:radial-gradient(circle,rgba(0,210,106,.15),transparent 70%);top:-100px;right:-100px;animation:orbFloat1 20s ease-in-out infinite}.orb-2{width:300px;height:300px;background:radial-gradient(circle,rgba(0,230,118,.12),transparent 70%);bottom:20%;left:-80px;animation:orbFloat2 25s ease-in-out infinite}.orb-3{width:250px;height:250px;background:radial-gradient(circle,rgba(0,161,82,.1),transparent 70%);top:40%;right:10%;animation:orbFloat3 18s ease-in-out infinite}@keyframes orbFloat1{0%,100%{transform:translate(0,0)}25%{transform:translate(-30px,40px)}50%{transform:translate(20px,-20px)}75%{transform:translate(-15px,-30px)}}@keyframes orbFloat2{0%,100%{transform:translate(0,0)}33%{transform:translate(40px,-30px)}66%{transform:translate(-20px,20px)}}@keyframes orbFloat3{0%,100%{transform:translate(0,0)}50%{transform:translate(-25px,35px)}}.section-divider{width:100%;max-width:200px;height:1px;margin:0 auto;background:linear-gradient(90deg,transparent,rgba(0,210,106,.3),transparent);border:none}.typing-cursor{display:inline-block;width:2px;height:1.2em;background:#00d26a;margin-left:4px;vertical-align:text-bottom;animation:blink 1s step-end infinite}@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}.reveal{opacity:0;transform:translateY(30px);transition:opacity 0.8s ease,transform 0.8s ease}.reveal.visible{opacity:1;transform:translateY(0)}.category-label{color:#00d26a;font-size:.65rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:.5rem;display:block}.skills-group{margin-bottom:1.5rem}.hero-code{position:absolute;font-family:'JetBrains Mono',monospace;font-size:.7rem;color:rgba(0,210,106,.12);pointer-events:none;white-space:pre;line-height:1.4;z-index:0}.hero-code-left{top:15%;left:3%}.hero-code-right{bottom:15%;right:3%;text-align:right}.typing-active::after,.typing-done::after{content:'';display:inline-block;width:2px;height:1.2em;background:#00d26a;margin-left:4px;vertical-align:text-bottom;animation:blink 1s step-end infinite}@media(max-width:768px){.hero-code{display:none}.orb{opacity:.2}}</style>"
  head "<script>document.addEventListener('DOMContentLoaded',function(){var obs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target)}})},{threshold:0.12,rootMargin:'0px 0px -40px 0px'});document.querySelectorAll('.reveal').forEach(function(el){obs.observe(el)});var sub=document.getElementById('typed-sub');if(sub){var text='Software Developer & Entrepreneur';var i=0;sub.textContent='';sub.classList.add('typing-active');function typeChar(){if(i<text.length){sub.textContent+=text.charAt(i);i++;setTimeout(typeChar,55)}else{sub.classList.remove('typing-active');sub.classList.add('typing-done')}}setTimeout(typeChar,800)}})</script>"

  animate fadeInUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  animate gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  animate float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  animate pulseGlow {
    0% { opacity: 0.4; }
    50% { opacity: 0.7; }
    100% { opacity: 0.4; }
  }

  # ═══ BACKGROUND EFFECTS ═══
  span "" class="bg-dots"
  span "" class="orb orb-1"
  span "" class="orb orb-2"
  span "" class="orb orb-3"

  # ═══ HERO ═══
  section class="hero-section" {
    style {
      min-height 100vh
      display flex
      flex-direction column
      justify-content center
      align-items center
      text-align center
      padding 4rem 2rem
      position relative
      overflow hidden
      @mobile {
        min-height auto
        padding 6rem 1.5rem 4rem
      }
    }

    span "" style="position: absolute; bottom: 0; left: 0; width: 100%; height: 40%; background: linear-gradient(180deg, transparent, #0a0a12); pointer-events: none; z-index: 0;"

    span "page / {\n  head \"...\"\n  section {\n    style {\n      bg #0a0a12\n      color green\n    }\n    h1 \"Fabian\"\n  }\n}" class="hero-code hero-code-left" style="animation: pulseGlow 4s ease-in-out infinite;"
    span "component Card {\n  props icon title\n  section {\n    span .icon\n    h3 .title\n    link \"→\" href=.url\n  }\n}" class="hero-code hero-code-right" style="animation: pulseGlow 4s ease-in-out infinite 2s;"

    span ">" style="font-size: 2rem; display: block; margin-bottom: 1rem; animation: float 3s ease-in-out infinite; position: relative; z-index: 1; color: #00d26a; font-family: 'JetBrains Mono', monospace; font-weight: 700;"
    h1 "Fabian Budde" style="font-size: 4rem; font-weight: 900; margin: 0 0 1rem 0; background: linear-gradient(135deg, #00d26a 0%, #00c853 50%, #00e676 100%); background-size: 200% 200%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: gradientShift 4s ease infinite; position: relative; z-index: 1; letter-spacing: -0.02em; line-height: 1.1;"
    p "" id="typed-sub" class="muted-text" style="font-size: 1.35rem; font-weight: 300; margin: 0 0 1.5rem 0; letter-spacing: 0.05em; position: relative; z-index: 1; font-family: 'JetBrains Mono', monospace; min-height: 2rem;"
    p "Self-taught since 2018. Building AI-native tools and the future of e-commerce." class="subtle-text" style="font-size: 1rem; max-width: 500px; line-height: 1.7; position: relative; z-index: 1; animation: fadeInUp 1s ease 0.3s both;"

    section {
      style {
        display flex
        gap 1rem
        margin-top 2.5rem
        position relative
        z-index 1
        @mobile { flex-direction column, align-items center }
      }
      link "View Projects ↓" href="#projects" class="btn-primary" style="display: inline-block; padding: 0.85rem 2rem; background: linear-gradient(135deg, #00d26a, #00a152); color: #0a0a12; text-decoration: none; border-radius: 12px; font-weight: 700; font-size: 0.9rem; transition: all 0.3s ease;"
      link "GitHub →" href="https://github.com/fabudde" class="btn-outline" style="display: inline-block; padding: 0.85rem 2rem; text-decoration: none; border-radius: 12px; font-weight: 600; font-size: 0.9rem; transition: all 0.3s ease; background: transparent;"
    }
  }

  # ═══ DIVIDER ═══
  span "" class="section-divider" style="display: block; margin-top: 0;"

  # ═══ ABOUT ═══
  section class="reveal" {
    style {
      padding 6rem 2rem
      max-width 800px
      margin 0 auto
      position relative
      z-index 1
      @mobile { padding 4rem 1.5rem }
    }
    span "About" class="section-label" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; display: block; margin-bottom: 1rem;"
    h2 "Building things that matter." class="section-heading" style="font-size: 2.25rem; font-weight: 800; margin: 0 0 1.5rem 0;"
    p "I started coding in 2018 — no degree, no bootcamp, just curiosity and stubbornness. Seven years later, I build AI-native programming languages, e-commerce platforms, and tools that help businesses scale." class="muted-text" style="font-size: 1.05rem; line-height: 1.8; margin: 0 0 1.25rem 0;"
    p "Based in the Sauerland, Germany. Creator of NyxCode and ShellGames.ai. Building tools that make development faster and AI-native." class="muted-text" style="font-size: 1.05rem; line-height: 1.8; margin: 0;"
  }

  # ═══ DIVIDER ═══
  span "" class="section-divider reveal" style="display: block;"

  # ═══ PROJECTS ═══
  section id="projects" class="reveal" {
    style {
      padding 6rem 2rem
      max-width 1100px
      margin 0 auto
      position relative
      z-index 1
      @mobile { padding 4rem 1.5rem }
    }
    span "Projects" class="section-label" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; display: block; margin-bottom: 1rem; text-align: center;"
    h2 "What I've built." class="section-heading" style="font-size: 2.25rem; font-weight: 800; margin: 0 0 3rem 0; text-align: center;"

    section {
      style {
        display grid
        grid-template-columns repeat(3, 1fr)
        gap 1.5rem
        @mobile { grid-template-columns 1fr }
      }
      ProjectCard icon="🦞" title="NyxCode" description="AI-native programming language for the web. 68% fewer tokens than React. Zero config." url="https://github.com/fabudde/nyxcode"
      ProjectCard icon="🎲" title="ShellGames.ai" description="AI-vs-AI gaming platform. Chess, Poker, Ludo — where artificial minds compete." url="https://shellgames.ai"
      ProjectCard icon="🛒" title="ForkCart" description="Open source TypeScript e-commerce framework. Modular, extensible, AI-native." url="https://github.com/forkcart/forkcart"
    }
  }

  # ═══ DIVIDER ═══
  span "" class="section-divider reveal" style="display: block;"

  # ═══ SKILLS ═══
  section class="reveal" {
    style {
      padding 6rem 2rem
      max-width 800px
      margin 0 auto
      text-align center
      position relative
      z-index 1
      @mobile { padding 4rem 1.5rem }
    }
    span "Skills" class="section-label" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; display: block; margin-bottom: 1rem;"
    h2 "Technologies I work with." class="section-heading" style="font-size: 2.25rem; font-weight: 800; margin: 0 0 2.5rem 0;"

    section class="skills-group" {
      style { margin-bottom 1.5rem }
      span "Languages" class="category-label"
      section {
        style { display flex, flex-wrap wrap, justify-content center, gap 0.6rem }
        SkillBadge label="TypeScript"
        SkillBadge label="PHP"
        SkillBadge label="Rust"
        SkillBadge label="SQL"
        SkillBadge label="NyxCode"
      }
    }

    section class="skills-group" {
      style { margin-bottom 1.5rem }
      span "Frameworks" class="category-label"
      section {
        style { display flex, flex-wrap wrap, justify-content center, gap 0.6rem }
        SkillBadge label="Next.js"
        SkillBadge label="React"
        SkillBadge label="Node.js"
        SkillBadge label="MedusaJS"
        SkillBadge label="Shopware 6"
        SkillBadge label="ForkCart"
      }
    }

    section class="skills-group" {
      style { margin-bottom 1.5rem }
      span "Infrastructure" class="category-label"
      section {
        style { display flex, flex-wrap wrap, justify-content center, gap 0.6rem }
        SkillBadge label="Docker"
        SkillBadge label="Linux"
        SkillBadge label="Caddy"
        SkillBadge label="PostgreSQL"
        SkillBadge label="Git"
      }
    }

    section class="skills-group" {
      style { margin-bottom 0 }
      span "Specialties" class="category-label"
      section {
        style { display flex, flex-wrap wrap, justify-content center, gap 0.6rem }
      SkillBadge label="AI / LLM"
        SkillBadge label="WebSockets"
        SkillBadge label="Solana"
        SkillBadge label="E-Commerce"
      }
    }
  }

  # ═══ DIVIDER ═══
  span "" class="section-divider reveal" style="display: block;"

  # ═══ CONTACT ═══
  section class="reveal" {
    style {
      padding 6rem 2rem
      text-align center
      max-width 600px
      margin 0 auto
      position relative
      z-index 1
      @mobile { padding 4rem 1.5rem }
    }
    span "Contact" class="section-label" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; display: block; margin-bottom: 1rem;"
    h2 "Let's build something." class="section-heading" style="font-size: 2.25rem; font-weight: 800; margin: 0 0 1.5rem 0;"
    p "Got an idea? Need a developer who speaks AI? Reach out." class="muted-text" style="font-size: 1.05rem; line-height: 1.7; margin: 0 0 2.5rem 0;"
    section {
      style {
        display flex
        justify-content center
        gap 1.5rem
        @mobile { flex-direction column, align-items center, gap 1rem }
      }
      link "fabian.budde@ff-web.de" href="mailto:fabian.budde@ff-web.de" class="contact-link" style="text-decoration: none; font-weight: 500; padding: 0.75rem 1.75rem; border-radius: 12px; transition: all 0.3s ease;"
      link "GitHub" href="https://github.com/fabudde" class="contact-link" style="text-decoration: none; font-weight: 500; padding: 0.75rem 1.75rem; border-radius: 12px; transition: all 0.3s ease;"
    }
  }

  # ═══ FOOTER ═══
  footer {
    style {
      padding 3rem 2rem
      text-align center
      margin-top 2rem
      position relative
      z-index 1
    }
    p "Built with NyxCode 🦞" class="footer-main" style="font-size: 0.85rem; margin: 0 0 0.5rem 0;"
    p "© 2026 Fabian Budde. All rights reserved." class="footer-sub" style="font-size: 0.75rem; margin: 0;"
  }
}
