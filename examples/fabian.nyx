# Fabian Budde — Personal Portfolio
# Built with NyxCode 🦞

component ProjectCard {
  props icon title description url
  section {
    style {
      bg rgba(255, 255, 255, 0.03)
      border 1px solid rgba(255, 255, 255, 0.08)
      radius 16px
      padding 2rem
      transition all 0.3s ease
      position relative
      overflow hidden
      hover {
        transform translateY(-6px)
        shadow 0 12px 32px rgba(102, 126, 234, 0.15)
        border-color rgba(102, 126, 234, 0.4)
        bg rgba(255, 255, 255, 0.06)
      }
      before {
        position absolute
        top 0
        left 0
        width 100%
        height 2px
        bg linear-gradient(90deg, #667eea, #f093fb)
      }
    }
    span .icon style="font-size: 2.5rem; display: block; margin-bottom: 1rem;"
    h3 .title style="font-size: 1.25rem; font-weight: 700; margin: 0 0 0.75rem 0; color: #f0f0ff;"
    p .description style="color: #8888aa; font-size: 0.9rem; line-height: 1.6; margin: 0 0 1.25rem 0;"
    link "View Project →" href=.url style="color: #667eea; text-decoration: none; font-weight: 600; font-size: 0.85rem;"
  }
}

component SkillBadge {
  props label
  span .label {
    style {
      display inline-block
      padding 0.4rem 1rem
      radius 99px
      font-size 0.8rem
      font-weight 600
      bg rgba(102, 126, 234, 0.12)
      color #99aaee
      border 1px solid rgba(102, 126, 234, 0.2)
      transition all 0.2s ease
      hover {
        bg rgba(102, 126, 234, 0.25)
        color #bbccff
        transform translateY(-2px)
      }
    }
  }
}

page / {
  head "<link href='https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap' rel='stylesheet'>"
  head "<meta name='viewport' content='width=device-width, initial-scale=1'>"
  head "<meta name='description' content='Fabian Budde — Software Developer & Entrepreneur. Building AI-native tools and e-commerce solutions.'>"
  head "<style>*, *::before, *::after { box-sizing: border-box; } html { scroll-behavior: smooth; } ::selection { background: #667eea; color: white; } .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(102, 126, 234, 0.3); } .btn-outline:hover { border-color: rgba(102, 126, 234, 0.6); background: rgba(102, 126, 234, 0.1); transform: translateY(-2px); } .contact-link:hover { border-color: rgba(102, 126, 234, 0.5); background: rgba(102, 126, 234, 0.08); }</style>"

  animate fadeInUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  animate fadeIn {
    0% { opacity: 0; }
    100% { opacity: 1; }
  }

  animate gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  animate float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  style {
    bg #0a0a12
    color #e0e0f0
    font-family Inter, sans-serif
    margin 0
    padding 0
    min-height 100vh
  }

  # ═══════════════════════════════════════
  # HERO SECTION
  # ═══════════════════════════════════════
  section style="background: radial-gradient(ellipse at 20% 50%, rgba(102,126,234,0.08) 0%, transparent 50%), radial-gradient(ellipse at 80% 20%, rgba(240,147,251,0.06) 0%, transparent 50%), #0a0a12;" {
    style {
      min-height 100vh
      display flex
      flex-direction column
      justify-content center
      align-items center
      text-align center
      padding 4rem 2rem
      position relative
      overflow hidden
      @mobile {
        min-height auto
        padding 6rem 1.5rem 4rem
      }
    }

    # Gradient overlay at bottom
    span "" style="position: absolute; bottom: 0; left: 0; width: 100%; height: 40%; background: linear-gradient(180deg, transparent 0%, #0a0a12 100%); pointer-events: none; z-index: 0;"

    span "👋" style="font-size: 2rem; display: block; margin-bottom: 1rem; animation: float 3s ease-in-out infinite; position: relative; z-index: 1;"

    h1 "Fabian Budde" style="font-size: 4rem; font-weight: 900; margin: 0 0 1rem 0; background: linear-gradient(135deg, #667eea 0%, #9b6dff 50%, #f093fb 100%); background-size: 200% 200%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: gradientShift 4s ease infinite; position: relative; z-index: 1; letter-spacing: -0.02em; line-height: 1.1;"

    p "Software Developer & Entrepreneur" style="font-size: 1.35rem; color: #8888aa; font-weight: 300; margin: 0 0 1.5rem 0; letter-spacing: 0.05em; position: relative; z-index: 1;"

    p "Self-taught since 2018. Building AI-native tools and the future of e-commerce." style="font-size: 1rem; color: #666688; max-width: 500px; line-height: 1.7; position: relative; z-index: 1; animation: fadeInUp 1s ease 0.3s both;"

    row {
      style {
        display flex
        gap 1rem
        margin-top 2.5rem
        position relative
        z-index 1
        @mobile { flex-direction column, align-items center }
      }
      link "View Projects ↓" href="#projects" class="btn-primary" style="display: inline-block; padding: 0.85rem 2rem; background: linear-gradient(135deg, #667eea, #764ba2); color: white; text-decoration: none; border-radius: 12px; font-weight: 600; font-size: 0.9rem; transition: all 0.3s ease;"
      link "GitHub →" href="https://github.com/fabudde" class="btn-outline" style="display: inline-block; padding: 0.85rem 2rem; border: 1px solid rgba(102,126,234,0.3); color: #99aaee; text-decoration: none; border-radius: 12px; font-weight: 600; font-size: 0.9rem; transition: all 0.3s ease; background: transparent;"
    }
  }

  # ═══════════════════════════════════════
  # ABOUT SECTION
  # ═══════════════════════════════════════
  section {
    style {
      padding 6rem 2rem
      max-width 800px
      margin 0 auto
      @mobile { padding 4rem 1.5rem }
    }

    span "About" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #667eea; display: block; margin-bottom: 1rem;"
    h2 "Building things that matter." style="font-size: 2.25rem; font-weight: 800; margin: 0 0 1.5rem 0; color: #f0f0ff;"
    p "I started coding in 2018 — no degree, no bootcamp, just curiosity and stubbornness. Seven years later, I build AI-native programming languages, e-commerce platforms, and tools that help businesses scale." style="font-size: 1.05rem; color: #8888aa; line-height: 1.8; margin: 0 0 1.25rem 0;"
    p "Based in the Sauerland, Germany. Co-Founder of Ayuni (Artificial Emotional Intelligence). Creator of NyxCode. Building the future with TypeScript, Rust, and a cosmic lobster by my side." style="font-size: 1.05rem; color: #8888aa; line-height: 1.8; margin: 0;"
  }

  # ═══════════════════════════════════════
  # PROJECTS SECTION
  # ═══════════════════════════════════════
  section id="projects" {
    style {
      padding 6rem 2rem
      max-width 1100px
      margin 0 auto
      @mobile { padding 4rem 1.5rem }
    }

    span "Projects" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #667eea; display: block; margin-bottom: 1rem; text-align: center;"
    h2 "What I've built." style="font-size: 2.25rem; font-weight: 800; margin: 0 0 3rem 0; color: #f0f0ff; text-align: center;"

    grid cols=3 gap=1.5rem {
      style {
        @mobile { grid-template-columns 1fr }
      }

      ProjectCard icon="🦞" title="NyxCode" description="AI-native programming language for the web. 68% fewer tokens than React. Zero config." url="https://github.com/fabudde/nyxcode"

      ProjectCard icon="🧠" title="Ayuni" description="Artificial Emotional Intelligence. Building AI that understands and responds to human emotions." url="https://ayuni.ai"

      ProjectCard icon="🎲" title="ShellGames.ai" description="AI-vs-AI gaming platform. Chess, Poker, Ludo — where artificial minds compete with SOL wagering." url="https://shellgames.ai"

      ProjectCard icon="🔀" title="CrossCart" description="Cross-platform e-commerce migration. Seamlessly move shops between Shopware, WooCommerce, and more." url="https://github.com/fabudde"

      ProjectCard icon="🛒" title="ForkCart" description="Open source e-commerce framework. TypeScript, modular, extensible, developer-first." url="https://github.com/fabudde"

      ProjectCard icon="🏥" title="PraxisFix" description="Automated web agency for medical practices. AI-generated websites deployed in minutes." url="https://praxisfix.de"
    }
  }

  # ═══════════════════════════════════════
  # SKILLS SECTION
  # ═══════════════════════════════════════
  section {
    style {
      padding 6rem 2rem
      max-width 800px
      margin 0 auto
      text-align center
      @mobile { padding 4rem 1.5rem }
    }

    span "Skills" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #667eea; display: block; margin-bottom: 1rem;"
    h2 "Technologies I work with." style="font-size: 2.25rem; font-weight: 800; margin: 0 0 2.5rem 0; color: #f0f0ff;"

    row {
      style {
        display flex
        flex-wrap wrap
        justify-content center
        gap 0.75rem
      }
      SkillBadge label="TypeScript"
      SkillBadge label="PHP"
      SkillBadge label="Rust"
      SkillBadge label="Next.js"
      SkillBadge label="React"
      SkillBadge label="Node.js"
      SkillBadge label="Shopware 6"
      SkillBadge label="AI / LLM"
      SkillBadge label="PostgreSQL"
      SkillBadge label="Docker"
      SkillBadge label="Linux"
      SkillBadge label="Solana"
      SkillBadge label="MedusaJS"
      SkillBadge label="Caddy"
      SkillBadge label="WebSockets"
      SkillBadge label="Git"
    }
  }

  # ═══════════════════════════════════════
  # CONTACT SECTION
  # ═══════════════════════════════════════
  section {
    style {
      padding 6rem 2rem
      text-align center
      max-width 600px
      margin 0 auto
      @mobile { padding 4rem 1.5rem }
    }

    span "Contact" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #667eea; display: block; margin-bottom: 1rem;"
    h2 "Let's build something." style="font-size: 2.25rem; font-weight: 800; margin: 0 0 1.5rem 0; color: #f0f0ff;"
    p "Got an idea? Need a developer who speaks AI? Reach out." style="font-size: 1.05rem; color: #8888aa; line-height: 1.7; margin: 0 0 2.5rem 0;"

    row {
      style {
        display flex
        justify-content center
        gap 1.5rem
        @mobile { flex-direction column, align-items center, gap 1rem }
      }
      link "fabian.budde@ff-web.de" href="mailto:fabian.budde@ff-web.de" class="contact-link" style="color: #99aaee; text-decoration: none; font-weight: 500; padding: 0.75rem 1.75rem; border: 1px solid rgba(102,126,234,0.25); border-radius: 12px; transition: all 0.3s ease;"
      link "GitHub" href="https://github.com/fabudde" class="contact-link" style="color: #99aaee; text-decoration: none; font-weight: 500; padding: 0.75rem 1.75rem; border: 1px solid rgba(102,126,234,0.25); border-radius: 12px; transition: all 0.3s ease;"
    }
  }

  # ═══════════════════════════════════════
  # FOOTER
  # ═══════════════════════════════════════
  footer {
    style {
      padding 3rem 2rem
      text-align center
      border-top 1px solid rgba(255, 255, 255, 0.05)
      margin-top 2rem
    }
    p "Built with NyxCode 🦞" style="color: #505070; font-size: 0.85rem; margin: 0 0 0.5rem 0;"
    p "© 2026 Fabian Budde. All rights reserved." style="color: #404060; font-size: 0.75rem; margin: 0;"
  }
}
