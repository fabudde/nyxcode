# Full-Stack NyxCode Demo
# 30 lines → complete app with DB, Auth, CRUD API

table users {
  name text required
  email email unique
  password text required
  role text default="user"
  created auto
}

table posts {
  title text required
  body text
  author users
  published bool default=false
  created auto
}

security {
  table users
  login email password
  token jwt
  protect /api/posts
}

page / {
  h1 "Full-Stack NyxCode"
  p "This app was generated from 30 lines of NyxCode."
  p "It includes: SQLite database, REST API, JWT auth, and this page."
}
