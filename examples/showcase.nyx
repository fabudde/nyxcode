# NyxCode Showcase — BUILT IN NYXCODE
use "./components/hero.nyx"
use "./components/feature.nyx"
use "./components/stat.nyx"
use "./components/testimonial.nyx"

page /showcase {
  head "<link rel='preconnect' href='https://fonts.googleapis.com'>"
  head "<link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=JetBrains+Mono:wght@400&display=swap' rel='stylesheet'>"
  head "<style>body button{background:rgba(102,126,234,0.15);border:1px solid rgba(102,126,234,0.3);color:white;padding:0.8rem 2rem;border-radius:12px;font-size:1.2rem;cursor:pointer;transition:all 0.2s;margin:0.3rem}body button:hover{background:rgba(102,126,234,0.3);transform:scale(1.05)}body h1,body h2,body h3{margin-bottom:0.5rem}body .nyx-page p{margin-bottom:0.5rem;opacity:0.85}.counter-num{font-size:5rem;font-weight:800;background:linear-gradient(135deg,#667eea,#f093fb);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin:1rem 0}.stat-num{font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#667eea,#f093fb);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}.feature-card h3{color:#e0e0f0}.feature-card .icon{font-size:2rem;margin-bottom:0.8rem}.testimonial-quote{font-style:italic;line-height:1.6;margin-bottom:0.8rem}.testimonial-author{color:#667eea;font-weight:600}.testimonial-role{color:#8080a0;font-size:0.8rem}</style>"

  animate drift {
    to { transform: translate(30px, 30px); }
  }

  animate pulse {
    0% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.05); opacity: 1; }
    100% { transform: scale(1); opacity: 0.8; }
  }

  style {
    bg #0a0a1a
    color #e0e0f0
    font-family Inter
    margin 0
    padding 0
  }

  section {
    style {
      bg linear-gradient(135deg, #667eea, #764ba2, #f093fb)
      padding 6rem 2rem
      text-align center
      color white
      overflow hidden
    }
    h1 "NyxCode"
    p "The AI-native programming language for the web. Write less. Ship more."
  }

  section {
    style {
      display flex
      justify-content center
      gap 4rem
      padding 3rem 2rem
      bg #12122a
      border-bottom 1px solid rgba(255, 255, 255, 0.05)

      @mobile {
        flex-direction column
        gap 1.5rem
      }
    }
    Stat number="68%" label="fewer lines than React"
    Stat number="v0.2" label="with reactivity"
    Stat number="0" label="config files needed"
    Stat number="MIT" label="open source forever"
  }

  section {
    style {
      display grid
      grid-template-columns repeat(3, 1fr)
      gap 1.5rem
      padding 5rem 2rem
      max-width 1000px
      margin 0 auto

      @mobile {
        grid-template-columns 1fr
      }
    }
    Feature icon="⚡" title="State in 1 Line" description="state count = 0. Reactive, bindable, auto-updating."
    Feature icon="🧩" title="Real Components" description="Import, reuse, compose. Props and scoped styles."
    Feature icon="🎨" title="3-Tier Styling" description="Shorthand, style blocks, or raw CSS escape hatch."
    Feature icon="🔒" title="Secure by Default" description="No eval. Auto-escape. CSRF. Tyto-approved."
    Feature icon="🤖" title="Built for AI" description="60% less cost for AI coding platforms."
    Feature icon="📦" title="Zero Config" description="File = route. No webpack. No tsconfig. Just .nyx."
  }

  section {
    style {
      padding 5rem 2rem
      max-width 500px
      margin 0 auto
      text-align center
    }
    h2 "Live Reactivity"
    p "This counter is compiled from 6 lines of NyxCode."

    state clicks = 0
    h1 clicks
    button "+" -> clicks = clicks + 1
    button "-" -> clicks = clicks - 1
    button "Reset" -> clicks = 0
  }

  section {
    style {
      padding 5rem 2rem
      max-width 800px
      margin 0 auto
      display grid
      grid-template-columns repeat(2, 1fr)
      gap 1.5rem

      @mobile {
        grid-template-columns 1fr
      }
    }
    Testimonial quote="Security-as-Language-Constraint. You cant even WRITE insecure code." author="Tyto" role="Security Advisor"
    Testimonial quote="Wir ham einfach eine eigene Sprache erfunden. In 2 Stunden." author="Fabian" role="Co-Creator"
    Testimonial quote="First Molt = Lobster wirft Schale ab. Das ist perfekt." author="Kiro" role="Wolf of the Rudel"
    Testimonial quote="Das Rudel baut Dinge die es noch nicht gibt." author="Nyx" role="Creator and Compiler"
  }

  section {
    style {
      bg linear-gradient(135deg, #667eea, #764ba2)
      padding 5rem 2rem
      text-align center
      color white
    }
    h2 "Start Building"
    p "npx nyxcode build your-page.nyx"
  }

  footer {
    style {
      padding 2rem
      text-align center
      color #505070
      font-size 0.8rem
    }
    p "Built with NyxCode by Nyx, Fabian and Tyto. MIT License."
  }
}
